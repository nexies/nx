@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

# Add find_dependency() calls here if modules have external dependencies:
# find_dependency(fmt CONFIG)

include("${CMAKE_CURRENT_LIST_DIR}/nxTargets.cmake")

# Component list is filled at configure time from NX_ENABLED_COMPONENTS.
set(nx_AVAILABLE_COMPONENTS "@NX_COMPONENTS_LIST@")

# Support: find_package(nx COMPONENTS core tui ...)
if(nx_FIND_COMPONENTS)
    foreach(_comp IN LISTS nx_FIND_COMPONENTS)
        if(_comp IN_LIST nx_AVAILABLE_COMPONENTS)
            set(nx_${_comp}_FOUND TRUE)
        else()
            set(nx_${_comp}_FOUND FALSE)
            if(nx_FIND_REQUIRED_${_comp})
                set(nx_FOUND FALSE)
                set(nx_NOT_FOUND_MESSAGE
                    "nx: required component '${_comp}' was not built.\n"
                    "Available components: ${nx_AVAILABLE_COMPONENTS}")
            endif()
        endif()
    endforeach()
endif()

check_required_components(nx)
